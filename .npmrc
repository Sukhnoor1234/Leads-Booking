; Reduces exposure to npm supply chain attacks.
;
; ignore-scripts: prevents install/postinstall scripts from auto-running.
; Most real malware in 2026's npm attacks executes through exactly this
; hook. None of this project's dependencies need install scripts to work,
; so this is safe to leave on.
ignore-scripts=true

; min-release-age: refuses to install any package version published less
; than 7 days ago. Malicious versions are usually caught and pulled within
; hours to days — this gives that window time to work before your machine
; ever touches a fresh release.
min-release-age=7
